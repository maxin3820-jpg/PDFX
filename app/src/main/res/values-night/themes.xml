<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme — instant launch -->
    <style name="Theme.PDFX" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">#0A0A0A</item>
    </style>

    <!-- Instant splash (no logo, no animation) -->
    <style name="Theme.PDFX.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0A0A0A</item>
        <item name="windowSplashScreenAnimationDuration">0</item>
        <item name="postSplashScreenTheme">@style/Theme.PDFX</item>
    </style>

</resources>
